<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape>
            <solid android:color="#183A5E" />
            <stroke android:width="1dp" android:color="#5AA9FF" />
            <corners android:radius="2dp" />
            <padding android:left="12dp" android:top="8dp" android:right="12dp" android:bottom="8dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#141D2D" />
            <stroke android:width="1dp" android:color="#22FFFFFF" />
            <corners android:radius="2dp" />
            <padding android:left="12dp" android:top="8dp" android:right="12dp" android:bottom="8dp" />
        </shape>
    </item>
</selector>